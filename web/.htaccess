RewriteEngine on
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule . index.php [L]

<RequireAny>
    # Rnova
    Require expr %{REMOTE_ADDR} == '79.175.47.33'

    # Custom
    Require expr %{REMOTE_ADDR} == '85.175.98.26'
    Require expr %{REMOTE_ADDR} == '85.172.10.111'
</RequireAny>

