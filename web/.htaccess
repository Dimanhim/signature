RewriteEngine on
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule . index.php [L]

<RequireAny>
    # VPN Rnova
    Require expr %{REMOTE_ADDR} == '79.175.47.33'

    # Пулы ПраймМедикал (клиенты, регистратуры, врачи)
    Require expr %{REMOTE_ADDR} == '37.112.63.179'
    Require expr %{REMOTE_ADDR} == '213.155.195.150'
    Require expr %{REMOTE_ADDR} == '31.132.168.5'
    Require expr %{REMOTE_ADDR} == '31.132.169.112'
    Require expr %{REMOTE_ADDR} == '176.214.46.224'
    Require expr %{REMOTE_ADDR} == '31.132.169.75'
    Require expr %{REMOTE_ADDR} == '212.103.119.5'
</RequireAny>
